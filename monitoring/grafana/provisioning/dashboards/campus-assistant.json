{
  "dashboard": {
    "id": null,
    "uid": "campus-assistant",
    "title": "Smart Campus Assistant",
    "tags": ["campus", "ai", "monitoring"],
    "timezone": "browser",
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "Total API Requests",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(http_requests_total{handler=\"/api/ask\"})",
            "legendFormat": "Total Requests"
          }
        ],
        "fieldConfig": {
          "defaults": { "thresholds": { "steps": [{"color": "green", "value": null}] } }
        }
      },
      {
        "id": 2,
        "title": "Request Rate (per minute)",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 12, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "rate(http_requests_total{handler=\"/api/ask\"}[1m]) * 60",
            "legendFormat": "Requests/min"
          }
        ]
      },
      {
        "id": 3,
        "title": "API Response Time (P95)",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{handler=\"/api/ask\"}[5m]))",
            "legendFormat": "P95 Latency"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 3},
                {"color": "red", "value": 5}
              ]
            },
            "max": 10
          }
        }
      },
      {
        "id": 4,
        "title": "Response Time Distribution",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{handler=\"/api/ask\"}[5m]))",
            "legendFormat": "P50 (Median)"
          },
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{handler=\"/api/ask\"}[5m]))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{handler=\"/api/ask\"}[5m]))",
            "legendFormat": "P99"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "s" } }
      },
      {
        "id": 5,
        "title": "HTTP Status Codes",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 6 },
        "targets": [
          {
            "expr": "sum by (status) (http_requests_total{handler=\"/api/ask\"})",
            "legendFormat": "{{status}}"
          }
        ]
      },
      {
        "id": 6,
        "title": "Error Rate",
        "type": "stat",
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 6 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{handler=\"/api/ask\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{handler=\"/api/ask\"}[5m])) * 100",
            "legendFormat": "Error %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 5}
              ]
            }
          }
        }
      }
    ]
  },
  "overwrite": true
}
